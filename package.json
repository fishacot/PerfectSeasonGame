{
  "name": "perfect-season-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "generate:data": "tsx scripts/generate-data.ts",
    "fetch:bbr-seasons": "node scripts/pipeline/fetch-bbr-seasons.mjs --delay 15000",
    "download:all-players": "node scripts/pipeline/download-all-players.mjs",
    "fetch:820-players": "node scripts/pipeline/fetch-820-players.mjs",
    "build:pools-cache": "node scripts/pipeline/build-pools-from-cache.mjs",
    "fetch:bbr-pools": "node scripts/pipeline/build-pools-from-cache.mjs && node scripts/pipeline/fetch-bbr-decade-pools.mjs --all --missing --resume --delay 5000",
    "export:nba-db": "node scripts/pipeline/export-nba-database.mjs",
    "validate:nba": "node scripts/validate-nba-stats.mjs",
    "validate:82-0-parity": "tsx scripts/validate-82-0-parity.mjs",
    "calibrate:82-0-fixtures": "tsx scripts/calibrate-820-fixtures.mjs",
    "extract:820-sim": "node scripts/pipeline/extract-820-sim.mjs",
    "generate:basketball-assets": "node scripts/generate-basketball-assets.mjs",
    "fetch:380-players": "node scripts/pipeline/fetch-380-players.mjs",
    "fetch:380-materials": "node scripts/pipeline/fetch-380-materials.mjs",
    "export:380-leagues": "node scripts/pipeline/export-380-leagues.mjs",
    "validate:football": "node scripts/validate-football-stats.mjs",
    "validate:nhl-parity": "tsx scripts/validate-nhl-parity.mjs",
    "ci": "npm run validate:nba && npm run validate:football && npm run validate:82-0-parity && npm run validate:nhl-parity && npm run lint && npm run build",
    "test:smoke": "node scripts/smoke-check.mjs",
    "check:sandbox-match": "tsx scripts/check-sandbox-match.mjs",
    "check:football-sim": "tsx scripts/check-football-sim.mjs",
    "test:e2e": "playwright test",
    "fetch:photos": "node scripts/fetch-player-photos.mjs"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.42.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}